# Virtual environment — not needed in git; run: bash scripts/bootstrap.sh
venv/
.venv/
env/

# Decryption key — never commit (whoever has it can read .secrets.enc).
# .secrets.env and .secrets.enc are NOT listed here so a private team repo may track them if you choose.

# Playwright session cookies — local only, expire; recreated after login
beta_admin_session.json
prod_admin_session.json
admin_session.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Job logs and uploaded session payloads (can be large)
sessions/

# Local-only env overrides
*.local.env
