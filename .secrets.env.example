# Copy to ".secrets.env" and fill in real values. Never commit ".secrets.env".
#
#   cp .secrets.env.example .secrets.env
#   nano .secrets.env
#   chmod 600 .secrets.env
#
# GitHub will never contain .secrets.env or .secrets.enc — they are in .gitignore.

# --- Beta Django admin ---
BETA_DJANGO_ADMIN_USERNAME=
BETA_DJANGO_ADMIN_PASSWORD=
BETA_DJANGO_ADMIN_URL=https://nkb-backend-ccbp-beta.earlywave.in/admin/

# --- Prod Django admin ---
PROD_DJANGO_ADMIN_USERNAME=
PROD_DJANGO_ADMIN_PASSWORD=
PROD_DJANGO_ADMIN_URL=https://nkb-backend-ccbp-prod-apis.ccbp.in/admin/

# Optional: Jupyter / other scripts (if your team uses them)
# BETA_JUPYTER_PASSWORD=
# PROD_JUPYTER_PASSWORD=

# Optional: if evaluation metrics admin URL 404s in your environment
# DJANGO_EVAL_METRICS_MODEL_PATH=nkb_question/codingquestiontestcaseevalutionmetrics/
